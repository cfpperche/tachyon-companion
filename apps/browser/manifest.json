{
  "manifest_version": 3,
  "name": "Tachyon Companion",
  "description": "Pair your browser with a local Tachyon engine — message agents, tab tools, approvals.",
  "version": "0.5.0",
  "action": {
    "default_title": "Open Tachyon Companion",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage", "sidePanel", "tabs"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://[::1]/*"
  ],
  "optional_host_permissions": ["http://*/*", "https://*/*", "<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "116"
}
