{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["chrome"],
    "paths": {
      "react": ["../../node_modules/preact/compat/"],
      "react-dom": ["../../node_modules/preact/compat/"],
      "react/jsx-runtime": ["../../node_modules/preact/jsx-runtime"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["src/background.ts"]
}
